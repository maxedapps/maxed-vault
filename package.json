{
  "name": "maxed-vault",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "test": "bun run --filter '*' test",
    "check": "bun run --filter '*' check",
    "build:bin:client": "bun run --filter @maxed-vault/client build:bin",
    "build:bin:server": "bun run --filter @maxed-vault/server build:bin",
    "build:bin": "bun run build:bin:client && bun run build:bin:server",
    "build:bin:client:prod": "bun run --filter @maxed-vault/client build:bin:prod",
    "build:bin:server:prod": "bun run --filter @maxed-vault/server build:bin:prod",
    "build:bin:prod": "bun run build:bin:client:prod && bun run build:bin:server:prod"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "vitest": "^4.0.18"
  }
}
