{
  "name": "maxed-vault",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "test": "bun run --filter '*' test",
    "check": "bun run --filter '*' check",
    "build:bin": "bun run --filter @maxed-vault/app build:bin",
    "build:bin:prod": "bun run --filter @maxed-vault/app build:bin:prod",
    "build:bin:linux-x64": "bun run --filter @maxed-vault/app build:bin:linux-x64",
    "build:bin:darwin-arm64": "bun run --filter @maxed-vault/app build:bin:darwin-arm64"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "vitest": "^4.0.18"
  }
}
