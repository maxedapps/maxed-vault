VAULT_PORT=8420
# Optional override. Default DB path is OS-specific:
# - macOS: ~/Library/Application Support/maxedvault/vault.db
# - Linux: $XDG_DATA_HOME/maxedvault/vault.db or ~/.local/share/maxedvault/vault.db
# VAULT_DB_PATH=/absolute/path/to/vault.db

# Optional passphrase sources for non-interactive startup:
# VAULT_PASSPHRASE=change-me
# VAULT_PASSPHRASE_FILE=/absolute/path/to/passphrase.txt
