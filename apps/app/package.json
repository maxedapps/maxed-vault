{
  "name": "@maxed-vault/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build:bin": "bun build src/index.ts --compile --outfile dist/maxedvault",
    "build:bin:prod": "bun build src/index.ts --compile --minify --sourcemap --bytecode --outfile dist/maxedvault",
    "build:bin:linux-x64": "bun build src/index.ts --compile --target bun-linux-x64 --outfile dist/maxedvault-linux-x64",
    "build:bin:darwin-arm64": "bun build src/index.ts --compile --target bun-darwin-arm64 --outfile dist/maxedvault-darwin-arm64",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "vitest run"
  },
  "bin": {
    "maxedvault": "src/index.ts"
  }
}
